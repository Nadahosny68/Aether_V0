"""
pipelines/ingestion/fill_pollution_gaps.py
───────────────────────────────────────────
Reads missing_pollution_dates.csv (generated by data_cleaning.py),
fetches those specific dates from the Open-Meteo Air Quality API
(free, no API key needed), and merges them into pollution_clean.csv.

Run AFTER data_cleaning.py:
    python pipelines/ingestion/fill_pollution_gaps.py
    python pipelines/ingestion/fill_pollution_gaps.py --dry-run  (preview only)
"""

import os
import sys
import time
import argparse
import requests
import pandas as pd
from datetime import datetime, timedelta

ROOT = os.path.abspath(os.path.join(os.path.dirname(__file__), "..", ".."))
sys.path.insert(0, ROOT)

from utils.logger import get_logger
log = get_logger("fill_pollution_gaps")

STAGING_DIR   = os.path.join(ROOT, "data", "staging")
MISSING_PATH  = os.path.join(STAGING_DIR, "missing_pollution_dates.csv")
POLLUTION_PATH= os.path.join(STAGING_DIR, "pollution_clean.csv")

# Open-Meteo Air Quality API — completely free, no key required
# Same source as your original historical CSV
LAT, LON = 30.0626, 31.2497  # Cairo

OPENMETEO_URL = "https://air-quality-api.open-meteo.com/v1/air-quality"


def fetch_date_range(start_date: str, end_date: str) -> pd.DataFrame:
    """
    Fetch air quality data for a date range from Open-Meteo.
    Groups multiple missing dates into batches to minimise API calls.
    """
    params = {
        "latitude"          : LAT,
        "longitude"         : LON,
        "hourly"            : [
            "pm10", "pm2_5", "carbon_monoxide",
            "nitrogen_dioxide", "sulphur_dioxide", "ozone",
            "aerosol_optical_depth", "dust", "uv_index",
            "us_aqi", "european_aqi",
        ],
        "start_date"        : start_date,
        "end_date"          : end_date,
        "timezone"          : "Africa/Cairo",
    }

    log.info("Fetching %s → %s from Open-Meteo …", start_date, end_date)
    resp = requests.get(OPENMETEO_URL, params=params, timeout=30)

    if resp.status_code != 200:
        log.error("API error %d: %s", resp.status_code, resp.text[:200])
        return pd.DataFrame()

    data = resp.json()
    hourly = data.get("hourly", {})

    if not hourly or "time" not in hourly:
        log.warning("No hourly data returned for %s → %s", start_date, end_date)
        return pd.DataFrame()

    df = pd.DataFrame(hourly)
    df["time"] = pd.to_datetime(df["time"])
    df["date"] = df["time"].dt.date

    # Aggregate hourly → daily mean (same method as original CSV)
    agg_cols = [c for c in df.columns if c not in ["time", "date"]]
    daily = df.groupby("date")[agg_cols].mean().reset_index()

    # Rename to match existing pollution_clean.csv columns
    daily = daily.rename(columns={"pm2_5": "pm25", "us_aqi": "aqi"})

    log.info("Fetched %d daily rows", len(daily))
    return daily


def chunk_dates(dates: list, chunk_size: int = 30):
    """Split date list into chunks to batch API calls."""
    for i in range(0, len(dates), chunk_size):
        yield dates[i:i + chunk_size]


def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("--dry-run", action="store_true",
                        help="Show what would be fetched without writing files")
    args = parser.parse_args()

    # ── Load missing dates ─────────────────────────────────────────────────
    if not os.path.exists(MISSING_PATH):
        log.error(
            "missing_pollution_dates.csv not found.\n"
            "Run data_cleaning.py first to generate it."
        )
        sys.exit(1)

    missing_df = pd.read_csv(MISSING_PATH)
    missing_dates = sorted(pd.to_datetime(missing_df["date"]).dt.date.tolist())
    log.info("Missing dates to fill: %d", len(missing_dates))

    if not missing_dates:
        log.info("No missing dates — pollution data is already complete.")
        return

    if args.dry_run:
        log.info("Dry run — would fetch these dates:")
        for d in missing_dates[:20]:
            print(f"  {d}")
        if len(missing_dates) > 20:
            print(f"  ... and {len(missing_dates) - 20} more")
        return

    # ── Fetch in batches of 30 days ────────────────────────────────────────
    all_new = []

    for chunk in chunk_dates(missing_dates, chunk_size=30):
        start = str(chunk[0])
        end   = str(chunk[-1])

        new_data = fetch_date_range(start, end)

        if not new_data.empty:
            # Keep only dates we actually need (API may return extras)
            chunk_set = set(chunk)
            new_data  = new_data[new_data["date"].isin(chunk_set)]
            all_new.append(new_data)
            log.info("  Chunk %s → %s: got %d rows", start, end, len(new_data))

        time.sleep(0.5)  # be polite to the API

    if not all_new:
        log.warning("API returned no data for any missing dates.")
        return

    new_df = pd.concat(all_new, ignore_index=True)
    log.info("Total new rows fetched: %d", len(new_df))

    # ── Load existing pollution and merge ──────────────────────────────────
    existing = pd.read_csv(POLLUTION_PATH)
    existing["date"] = pd.to_datetime(existing["date"]).dt.date
    log.info("Existing pollution rows: %d", len(existing))

    # Align columns — add any missing columns with NaN
    for col in existing.columns:
        if col not in new_df.columns:
            new_df[col] = None
    new_df = new_df[[c for c in existing.columns if c in new_df.columns]]

    # Combine and deduplicate
    combined = pd.concat([existing, new_df], ignore_index=True)
    combined = combined.drop_duplicates(subset=["date"], keep="last")
    combined = combined.sort_values("date").reset_index(drop=True)

    # Fill any remaining nulls with median
    for col in combined.columns:
        if col != "date" and combined[col].isnull().any():
            combined[col] = combined[col].fillna(combined[col].median())

    log.info("Combined pollution rows: %d", len(combined))
    log.info("Date range: %s → %s", combined["date"].min(), combined["date"].max())

    # ── Save ───────────────────────────────────────────────────────────────
    combined.to_csv(POLLUTION_PATH, index=False)
    log.info("Saved updated pollution_clean.csv → %s", POLLUTION_PATH)

    # Report what's still missing
    filled      = set(new_df["date"])
    still_missing = set(missing_dates) - filled
    if still_missing:
        log.warning(
            "%d dates still missing after API fill (API may not have data for them): %s",
            len(still_missing), sorted(still_missing)[:10]
        )
    else:
        log.info("All gaps filled successfully.")

    print(f"\nDone. Added {len(new_df)} rows. Total pollution rows: {len(combined)}")


if __name__ == "__main__":
    main()